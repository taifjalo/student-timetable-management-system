<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<VBox prefHeight="200.0" prefWidth="100.0" BorderPane.alignment="CENTER" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1">
        <children>
            <HBox alignment="CENTER_LEFT" prefHeight="100.0">
                <children>
                    <Text fx:id="sectionTitleText" strokeType="OUTSIDE" strokeWidth="0.0" text="Group">
                        <font>
                            <Font size="18.0" />
                        </font>
                    </Text>
                    <Region HBox.hgrow="ALWAYS" />
                    <Button mnemonicParsing="false">
                        <graphic>
                            <ImageView fitHeight="10.0" fitWidth="15.0" pickOnBounds="true" preserveRatio="true">
                                <image>
                                    <Image url="@images/add_icon.png" />
                                </image>
                     <cursor>
                        <Cursor fx:constant="HAND" />
                     </cursor>
                            </ImageView>
                        </graphic>
               <cursor>
                  <Cursor fx:constant="HAND" />
               </cursor>
                    </Button>
                </children>
            </HBox>
            <VBox fx:id="groupsListContainer" prefHeight="200.0" prefWidth="100.0" spacing="10.0">
                <children>
                    <HBox alignment="CENTER_LEFT">
                        <children>
                            <Text strokeType="OUTSIDE" strokeWidth="0.0" text="Text" />
                            <Region HBox.hgrow="ALWAYS" />
                            <Button mnemonicParsing="false">
                                <graphic>
                                    <ImageView fitHeight="15.0" fitWidth="15.0" pickOnBounds="true" preserveRatio="true">
                                        <image>
                                            <Image url="@images/edit_dots_icon.png" />
                                        </image>
                                    </ImageView>
                                </graphic>
                     <cursor>
                        <Cursor fx:constant="HAND" />
                     </cursor>
                            </Button>
                        </children>
                    </HBox>
                    <HBox alignment="CENTER_LEFT" layoutX="10.0" layoutY="10.0">
                        <children>
                            <Text strokeType="OUTSIDE" strokeWidth="0.0" text="Text" />
                            <Region HBox.hgrow="ALWAYS" />
                            <Button mnemonicParsing="false">
                                <graphic>
                                    <ImageView fitHeight="15.0" fitWidth="15.0" pickOnBounds="true" preserveRatio="true">
                                        <image>
                                            <Image url="@images/edit_dots_icon.png" />
                                        </image>
                                    </ImageView>
                                </graphic>
                     <cursor>
                        <Cursor fx:constant="HAND" />
                     </cursor>
                            </Button>
                        </children>
                    </HBox>
                </children>
            </VBox>
        </children>
    </VBox>
