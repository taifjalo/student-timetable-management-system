<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox fx:id="popupRoot" prefWidth="320.0" spacing="0.0"
      style="-fx-background-color: white;"
      xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="org.controllers.NotificationsPopupController">

    <!-- Header -->
    <HBox alignment="CENTER_LEFT" style="-fx-background-color: white;">
        <padding><Insets bottom="12.0" left="16.0" right="16.0" top="14.0"/></padding>
        <Label text="%notifications.popup.title" style="-fx-font-size: 15; -fx-font-weight: bold;"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Label fx:id="markAllLabel" text="%notifications.popup.mark.all.as.read.button"
               style="-fx-text-fill: #00956D; -fx-cursor: hand; -fx-font-size: 12;"
               onMouseClicked="#handleMarkAllRead"/>
    </HBox>

    <Separator/>

    <!-- Notification list -->
    <ScrollPane fitToWidth="true" prefHeight="340.0"
                style="-fx-background: white; -fx-background-color: white; -fx-border-color: transparent;">
        <VBox fx:id="notificationList" spacing="0.0"
              style="-fx-background-color: white;"/>
    </ScrollPane>

</VBox>

