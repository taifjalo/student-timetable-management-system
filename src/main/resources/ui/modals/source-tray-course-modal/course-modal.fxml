<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<VBox maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" style="-fx-background-color: #F8F8F3;" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.controllers.CreateCourseModalController">
    <children>
        <VBox alignment="CENTER" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefWidth="600.0" spacing="10.0">
            <children>
                <HBox alignment="CENTER">
                    <children>
                        <Text fx:id="modalTitleLabel" strokeType="OUTSIDE" strokeWidth="0.0" text="%modal.create.course.title">
                            <font>
                                <Font size="28.0" />
                            </font>
                        </Text>
                    </children>
                </HBox>
                <VBox spacing="10.0">
                    <children>
                        <Label text="%modal.course.name.label" />
                        <TextField fx:id="groupNameField" promptText="%modal.course.prompt.text" style="-fx-pref-height: 40; -fx-border-color: grey; -fx-border-radius: 5;" />
                    </children>
                </VBox>
                <VBox layoutX="10.0" layoutY="26.0" spacing="10.0">
                    <children>
                        <HBox alignment="CENTER_LEFT">
                            <children>
                                <Label text="%modal.course.color.label" />
                            </children>
                        </HBox>
                  <MenuButton fx:id="colorPicker" maxWidth="1.7976931348623157E308" mnemonicParsing="false" text="%modal.course.select.color" />
                    </children>
                </VBox>
                <HBox alignment="CENTER">
                    <children>
                        <Button fx:id="deleteButton" layoutX="444.0" layoutY="10.0" mnemonicParsing="false" onAction="#handleDelete" style="-fx-background-color: #D03800; -fx-border-radius: 15;" text="%modal.course.delete.button" textFill="WHITE">
                            <font>
                                <Font size="16.0" />
                            </font>
                            <cursor>
                                <Cursor fx:constant="HAND" />
                            </cursor>
                        </Button>
                        <Region HBox.hgrow="ALWAYS" />
                        <Button fx:id="confirmButton" mnemonicParsing="false" onAction="#handleConfirm" style="-fx-background-color: #00956D; -fx-border-radius: 15;" text="%modal.course.save.button" textFill="WHITE">
                            <font>
                                <Font size="16.0" />
                            </font>
                            <cursor>
                                <Cursor fx:constant="HAND" />
                            </cursor></Button>
                    </children>
                    <VBox.margin>
                        <Insets top="10.0" />
                    </VBox.margin>
                </HBox>

            </children>
            <padding>
                <Insets bottom="30.0" left="50.0" right="50.0" top="30.0" />
            </padding>
        </VBox>
    </children>
</VBox>
